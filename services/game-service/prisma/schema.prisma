generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GameSpin {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id")
  roomId    String   @map("room_id")
  roundId   String   @map("round_id")
  gameId    String   @map("game_id")
  requestId String   @map("request_id")
  spinId    String   @map("spin_id")
  betAmount Int      @map("bet_amount")
  winAmount Int      @map("win_amount")
  symbols   Json
  balance   Int
  createdAt DateTime @default(now()) @map("created_at")
  round     GameRound @relation(fields: [roundId], references: [roundId])

  @@unique([userId, roundId, spinId])
  @@map("game_spins")
}

model GameRound {
  id          BigInt     @id @default(autoincrement())
  roundId     String     @unique @map("round_id")
  userId      String     @map("user_id")
  roomId      String     @map("room_id")
  status      String
  createdAt   DateTime   @default(now()) @map("created_at")
  completedAt DateTime?  @map("completed_at")
  spins       GameSpin[]
  actions     RoundAction[]

  @@map("game_rounds")
}

model RoundAction {
  id        BigInt    @id @default(autoincrement())
  roundId   String    @map("round_id")
  userId    String    @map("user_id")
  roomId    String    @map("room_id")
  action    String
  requestId String    @map("request_id")
  payload   Json
  result    Json?
  createdAt DateTime  @default(now()) @map("created_at")
  round     GameRound @relation(fields: [roundId], references: [roundId])

  @@unique([roundId, action, requestId])
  @@index([roundId, createdAt])
  @@map("round_actions")
}

model OutboxEvent {
  id          String    @id @default(uuid())
  eventKey    String    @unique @map("event_key")
  eventType   String    @map("event_type")
  payload     Json
  status      String    @default("pending")
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  @@index([status, createdAt])
  @@map("outbox_events")
}
